time_rwmh <- rwmh_time[3]
ess_per_time_bf <- ess_bf/time_bf
ess_per_time_rwmh <- ess_rwmh/time_rwmh
#log posterior
log_post_bf <- bf_chain[[4]]
log_post_rwmh <- rwmh_chain[[3]]
print(paste("Min ESS BF: ", ess_bf))
print(paste("Min ESS RWMH: ", ess_rwmh))
