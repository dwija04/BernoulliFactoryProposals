# Load packages
library(tidyverse)
library(gridExtra)
library(knitr)
library(kableExtra)
library(lme4)
library(DHARMa)
# Load data
load("uvD5to14.RData")
library(ggplot2)
library(tidyverse)
x <- uvD5to14
theme_set(theme_minimal(base_size = 8.5))
x <- x |>
mutate(count = as.numeric(count),
total = as.numeric(total))
sum(is.na(x$count))
x <- x |>
filter(!is.na(count) & total > 0) |>
mutate(
prop = as.numeric(count) / as.numeric(total)
)
x %>%
distinct(Exon, v.id, eventtype) %>%
count(Exon, eventtype) %>%
ggplot(aes(x = factor(Exon), y = n, fill = eventtype)) +
geom_col(position = "stack") +
labs(x = "Exon",
y = "Number of Variants",
fill = "Event Type") +
theme(text = element_text(size = 10))
pdf("variant-composition.pdf")
x %>%
distinct(Exon, v.id, eventtype) |>
count(Exon, eventtype) |>
ggplot(aes(x = factor(Exon), y = n, fill = eventtype)) +
geom_col(position = "stack") +
labs(x = "Exon",
y = "Number of Variants",
fill = "Event Type") +
theme(text = element_text(size = 10))
dev.off()
log_change_df <- x |>
group_by(Exon, eventtype, replicate, v.id) %>%
summarize(
log_prop_ratio = log(
(prop[day == "D14"]) /
(prop[day == "D5"])
),
.groups = "drop"
)
pdf("log-prop-density/pdf")
log_change_df <- x |>
group_by(Exon, eventtype, replicate, v.id) %>%
summarize(
log_prop_ratio = log(
(prop[day == "D14"]) /
(prop[day == "D5"])
),
.groups = "drop"
)
pdf("log-prop-density.pdf")
ggplot(log_change_df, aes(x = log_prop_ratio, fill = eventtype)) +
geom_density(alpha = 0.4) +
theme_minimal() +
labs(
x = "Log(Proportion Day14 / Proportion Day5)",
y = "Density",
fill = "Event Type"
) +
theme(text = element_text(size = 10))
dev.off()
library(ggridges)
x_wide <- x |>
select(Exon, label, eventtype, v.id, replicate, count, total, day) |>
pivot_wider(names_from = day, values_from = c(count, total)) |>
rename(count_d5 = count_D5, count_d14 = count_D14,
total_d5 = total_D5, total_d14 = total_D14) |>
mutate(
prop_d5        = count_d5  / total_d5,
prop_d14       = count_d14 / total_d14,
log_prop_ratio = log(prop_d14 / prop_d5)
) |>
filter(is.finite(log_prop_ratio))
pdf("exon-wise-density.pdf")
ggplot(x_wide |> filter(is.finite(log_prop_ratio)),
aes(x = log_prop_ratio, y = factor(Exon),
fill = eventtype, color = eventtype)) +
geom_density_ridges(alpha = 0.4, scale = 1.2) +
geom_vline(xintercept = 0, linetype = "dashed", color = "grey40") +
labs(title = "Log(Proportion Day14 / Proportion Day5) Density by Exon",
x = "Log Proportion Ratio", y = "Exon",
fill = "Variant Type", color = "Variant Type") +
theme_minimal()
dev.off()
