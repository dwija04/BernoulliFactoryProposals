#   facet_wrap(~ eventtype) +
#   labs(title = "Residuals vs Fitted",
#        x = "Posterior Mean Fitted", y = "Residual") +
#   theme_minimal()
ggplot(fitted_known,
aes(x = factor(Exon, levels = exon_levels),
y = residual, fill = eventtype)) +
geom_boxplot(outlier.size = 0.5) +
geom_hline(yintercept = 0, linetype = "dashed") +
labs(title = "Residuals by Exon -- check for systematic misfit",
x = "Exon", y = "Residual") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
post <- as.matrix(samples)
mu1_hat <- mean(post[, "mu[1]"])
mu2_hat <- mean(post[, "mu[2]"])
sigma1_hat <- mean(post[, "sigma[1]"])
sigma2_hat <- mean(post[, "sigma[2]"])
pi_hat <- mean(post[, "pi"])
u_hat <- colMeans(post[, grep("^u\\[", colnames(post))])
Y <- jags_data$Y_known
exon_idx <- jags_data$exon_known
mean1 <- mu1_hat + u_hat[exon_idx]
mean2 <- mu2_hat + u_hat[exon_idx]
dens1 <- dt((Y - mean1)/sigma1_hat, df=5) / sigma1_hat
dens2 <- dt((Y - mean2)/sigma2_hat, df=5) / sigma2_hat
prob_known <- (pi_hat * dens2) /
(pi_hat * dens2 + (1 - pi_hat) * dens1)
pred_known <- as.integer(prob_known > 0.5)
table(Predicted = pred_known + 1,
True = jags_data$Z_known)
mean(pred_known == jags_data$Z_known)
library(pROC)
roc_obj <- roc(jags_data$Z_known, prob_known)
auc(roc_obj)
plot(roc_obj)
