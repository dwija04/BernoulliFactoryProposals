log_prop_ratio = log(prop_d14 / prop_d5)
) |>
filter(is.finite(log_prop_ratio))
known_df <- x_wide |> filter(eventtype != "Missense")
miss_df  <- x_wide |> filter(eventtype == "Missense")
exon_levels <- levels(factor(x_wide$Exon))
known_df <- known_df |>
mutate(
exon_idx = as.integer(factor(Exon, levels = exon_levels)),
vid_idx  = as.integer(factor(v.id))
)
miss_df <- miss_df |>
mutate(
exon_idx = as.integer(factor(Exon, levels = exon_levels)),
vid_idx  = as.integer(factor(v.id))
)
miss_vid_fac <- factor(miss_df$v.id)
n_mv         <- nlevels(miss_vid_fac)
jags_data <- list(
Y_known         = known_df$log_prop_ratio,
Z_known         = ifelse(known_df$eventtype == "Synonymous", 1L, 2L),
exon_known      = known_df$exon_idx,
n_known         = nrow(known_df),
Y_miss          = miss_df$log_prop_ratio,
exon_miss       = miss_df$exon_idx,
vid_miss        = miss_df$vid_idx,
n_miss_obs      = nrow(miss_df),
n_miss_variants = n_mv,
n_exons         = length(exon_levels)
)
library(knitr)
diag_df <- data.frame(
Diagnostic = c(
"Gelman--Rubin ($\\hat{R}$)",
"Raftery--Lewis (total iters)",
"Convergence of $Z_{\\text{miss}}$"
),
Parameters = c(
"All continuous parameters",
"All parameters except $Z$",
"$Z_{\\text{miss}}$ across 4 chains"
),
Result = c(
"$\\hat{R} = 1.00$ for all",
"$< 20{,}000$ for all",
"Max range $= 0.00438$"
),
Conclusion = c(
"Chains have converged",
"2.5th pctile estimated to $\\pm 0.005$ w.p. 0.95",
"Latent variables have mixed well"
)
)
kable(diag_df, booktabs = TRUE, escape = FALSE,
col.names = c("Diagnostic", "Parameters", "Result", "Conclusion")) |>
kable_styling(font_size = 7, latex_options = "hold_position") |>
column_spec(4, width = "4cm")
library(knitr)
samples <- readRDS("samples.rds") ## Load samples
samp_mat <- as.matrix(samples)
posterior <- data.frame(
Parameter = c("beta0", "delta", "mu[1]", "mu[2]", "pi", "sigma[1]", "sigma[2]", "sigma_u"),
Mean      = c(-0.2580, 0.6602, 0.0721, -0.5881, 0.3838, 0.2443, 0.3971, 0.0364),
SD        = c(0.01990, 0.03092, 0.01617, 0.03176, 0.09822, 0.00832, 0.02293, 0.01965),
Q2.5      = c(-0.29888, 0.59990, 0.03830, -0.65158, 0.20208, 0.22845, 0.35447, 0.00386),
Q50       = c(-0.2574, 0.6601, 0.0727, -0.5877, 0.3807, 0.2441, 0.3963, 0.0345),
Q97.5     = c(-0.2203, 0.7212, 0.1027, -0.5272, 0.5835, 0.2611, 0.4443, 0.0808)
)
# Extra numeric values
ess <- c(20957.60, 26497.15, 36718.36, 20745.95, 160119.06, 59133.38, 57169.73, 19284.29)
# Combine into one data frame
df <- cbind(posterior, ESS = ess)
# Print the table in R Markdown
kable(df, caption = "Posterior Summary of Parameters and ESS", digits = 3) |>
kable_styling(font_size = 7, latex_options = c("hold_position", "scale_down"))
library(knitr)
re_df <- data.frame(
Parameter = c("$\\sigma_u$ (Exon SD)", "$\\sigma_1$ (Benign SD)",
"$\\sigma_2$ (Pathogenic SD)", "$\\delta$ (Class separation)"),
Value     = c(0.036, 0.244, 0.397, 0.660),
Interpretation = c(
"Exon explains $<3\\%$ of total variance — pooling across exons well-supported",
"Within-class spread for benign variants",
"Wider spread than benign — more heterogeneous functional disruption",
"95\\% CI: (0.60, 0.72) — strong, well-estimated separation between classes"
)
)
kable(re_df, booktabs = TRUE, escape = FALSE, digits = 3,
col.names = c("Parameter", "Posterior Mean", "Interpretation")) |>
kable_styling(font_size = 7, latex_options = "hold_position") |>
column_spec(3, width = "6.5cm")
fitted_known <- known_df |>
mutate(fitted   = colMeans(ppc_samples),
residual = log_prop_ratio - fitted)
u_mat <- samp_mat[, paste0("u[", 1:jags_data$n_exons, "]"), drop = FALSE]
n_post      <- 5000
draw_idx    <- sample(nrow(samp_mat), n_post)
ppc_samples <- matrix(NA, nrow = n_post, ncol = nrow(known_df))
for (s in seq_len(n_post)) {
d      <- draw_idx[s]
mu1    <- samp_mat[d, "mu[1]"]
mu2    <- samp_mat[d, "mu[2]"]
sig1   <- samp_mat[d, "sigma[1]"]   # directly, no sqrt needed
sig2   <- samp_mat[d, "sigma[2]"]
u_vals <- as.numeric(u_mat[d, known_df$exon_idx])
mu_i  <- ifelse(known_df$eventtype == "Synonymous",
mu1 + u_vals, mu2 + u_vals)
sig_i <- ifelse(known_df$eventtype == "Synonymous", sig1, sig2)
ppc_samples[s, ] <- rnorm(nrow(known_df), mu_i, sig_i)
}
# Multiple draw PPC
k        <- 50
draw_ids <- sample(nrow(ppc_samples), k)
ppc_long <- lapply(seq_len(k), function(i) {
data.frame(value     = ppc_samples[draw_ids[i], ],
eventtype = known_df$eventtype,
draw      = i)
}) |> bind_rows()
obs_long <- data.frame(
value     = known_df$log_prop_ratio,
eventtype = known_df$eventtype
)
ggplot() +
geom_density(data = ppc_long,
aes(x = value, group = draw),
color = "steelblue", alpha = 0.15, linewidth = 0.3) +
geom_density(data = obs_long,
aes(x = value),
color = "red", linewidth = 1) +
facet_wrap(~ eventtype, scales = "free") +
labs(title = "PPC: Observed (red) vs Posterior Predictive Draws (blue)",
x = "Log Proportion Ratio", y = "Density") +
theme_minimal()
fitted_known <- known_df |>
mutate(fitted   = colMeans(ppc_samples),
residual = log_prop_ratio - fitted)
# ggplot(fitted_known, aes(x = fitted, y = residual, color = eventtype)) +
#   geom_point(alpha = 0.4, size = 0.8) +
