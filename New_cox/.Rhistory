# install.packages("dbarts")
library(dbarts)
# Fit standard BART on the Friedman data (no latent variable)
bart_fit <- bart(x.train = X_obs,
y.train = y,
ntree   = m,
ndpost  = nd,
nskip   = burn,
verbose = FALSE)
library(drbart)
set.seed(42)
#    f(x) = 10*sin(pi*x1*x2) + 20*(x3-0.5)^2 + 10*x4 + 5*x5
n      <- 300
p_obs  <- 5          # observed covariates (x1..x5); Friedman uses exactly 5
sigma  <- 1.0
X_obs  <- matrix(runif(n * p_obs), nrow = n, ncol = p_obs)
friedman_mean <- function(X) {
10 * sin(pi * X[,1] * X[,2]) +
20 * (X[,3] - 0.5)^2         +
10 * X[,4]                   +
5 * X[,5]
}
f_true <- friedman_mean(X_obs)
y      <- f_true + rnorm(n, 0, sigma)
# ------------------------------------------------------------------------------
# 2. Prepend latent variable u as column 1 of x
#    drbart_l treats x[, 1] (index 0 in C++) as the latent u to be sampled.
#    Initialise u ~ Uniform(0, 1).
# ------------------------------------------------------------------------------
u_init <- runif(n)                              # latent variable, column 1
X_aug  <- cbind(u_init, X_obs)                 # n x (1 + p_obs)
p_aug  <- ncol(X_aug)                          # p_aug = 6
# drbart_l expects x as a flat numeric vector, row-major (p values per obs)
x_vec  <- as.numeric(t(X_aug))                 # length n * p_aug
n_cuts <- 100
make_cuts <- function(col_vals, n_cuts) {
quantile(col_vals, probs = seq(0, 1, length.out = n_cuts + 2)[-c(1, n_cuts + 2)],
names = FALSE)
}
xinfo_list <- vector("list", p_aug)
xinfo_list[[1]] <- seq(0, 1, length.out = n_cuts)   # uniform cuts for u
for (j in 2:p_aug) {
xinfo_list[[j]] <- make_cuts(X_aug[, j], n_cuts)
}
# ------------------------------------------------------------------------------
# 4. Sigma prior calibration (standard BART approach)
#    nu * lambda / (nu - 2) = shat^2  =>  lambda = shat^2 * (nu - 2) / nu
# ------------------------------------------------------------------------------
shat   <- sd(y)
nu     <- 3.0
lambda <- shat^2 * (nu - 2) / nu
x_vec  <- as.numeric(t(X_aug))                 # length n * p_aug
n_cuts <- 100
make_cuts <- function(col_vals, n_cuts) {
quantile(col_vals, probs = seq(0, 1, length.out = n_cuts + 2)[-c(1, n_cuts + 2)],
names = FALSE)
}
xinfo_list <- vector("list", p_aug)
xinfo_list[[1]] <- seq(0, 1, length.out = n_cuts)   # uniform cuts for u
for (j in 2:p_aug) {
xinfo_list[[j]] <- make_cuts(X_aug[, j], n_cuts)
}
shat   <- sd(y)
nu     <- 3.0
lambda <- shat^2 * (nu - 2) / nu
treef_name <- tempfile(fileext = ".txt")   # drbart_l writes trees here
burn       <- 500
nd         <- 1000
thin       <- 1
printevery <- 100
m          <- 50      # number of trees
alpha      <- 0.95    # tree prior: P(split) = alpha / (1 + depth)^beta
beta       <- 2.0
kfac       <- 2.0     # tau = (range y) / (2 * kfac * sqrt(m))
trunc_below <- as.integer(rep(0, n))   # no truncation
cat("Running drbart_l on Friedman data...\n")
fit <- drbart:::`drbart_l`(
y_           = y,
x_           = x_vec,
xinfo_list   = xinfo_list,
burn         = burn,
nd           = nd,
thin         = thin,
printevery   = printevery,
m            = m,
alpha        = alpha,
beta         = beta,
lambda       = lambda,
nu           = nu,
kfac         = kfac,
trunc_below  = trunc_below,
treef_name_  = treef_name
)
cat("\n--- Posterior sigma summary ---\n")
print(summary(fit$sigma))
cat("True sigma:", sigma, "\n")
cat("\n--- Posterior mean of u (first 6 obs) ---\n")
u_postmean <- colMeans(fit$uvals)
print(round(u_postmean[1:6], 3))
# Trace plot for sigma
plot(fit$sigma, type = "l",
xlab = "MCMC iteration", ylab = expression(sigma),
main = "Posterior draws of sigma — Friedman DGP")
abline(h = sigma, col = "red", lwd = 2, lty = 2)
legend("topright", legend = c("posterior draws", "true sigma"),
col = c("black", "red"), lty = c(1, 2))
# Histogram of posterior mean u across observations
hist(u_postmean, breaks = 30,
xlab = "Posterior mean of u",
main = "Distribution of E[u | y, X] across observations")
lines <- readLines(treef_name)
m_line <- which(lines == "50")   # m = 50 trees
header_end <- NA
for (i in m_line) {
if (lines[i + 1] == "6" && lines[i + 2] == "1000") {
header_end <- i + 2
break
}
}
cat("Trees start at line:", header_end + 1, "\n")
tree_lines <- lines[(header_end + 1):length(lines)]
p_aug    <- 6
var_names <- c("u (latent)", paste0("x", 1:5))
split_counts <- integer(p_aug)
i <- 1
while (i <= length(tree_lines)) {
line <- trimws(tree_lines[i])
if (line == "") { i <- i + 1; next }
n_nodes <- suppressWarnings(as.integer(line))
if (is.na(n_nodes)) { i <- i + 1; next }
# Read next n_nodes lines
for (j in seq_len(n_nodes)) {
node_line <- trimws(tree_lines[i + j])
tokens <- strsplit(node_line, "\\s+")[[1]]
if (length(tokens) == 4) {
var_idx <- as.integer(tokens[2])
if (!is.na(var_idx) && var_idx >= 1 && var_idx <= p_aug) {
split_counts[var_idx] <- split_counts[var_idx] + 1L
}
}
}
i <- i + n_nodes + 1
}
total_splits <- sum(split_counts)
split_df <- data.frame(
variable   = var_names,
splits     = split_counts,
proportion = round(split_counts / total_splits, 3)
)
split_df <- split_df[order(-split_df$splits), ]
rownames(split_df) <- NULL
print(split_df)
barplot(split_df$splits,
names.arg = split_df$variable,
col       = ifelse(split_df$variable == "u (latent)", "steelblue", "coral"),
main      = "Split frequency by variable across all posterior trees",
ylab      = "Total splits",
las       = 2)
i <- 1
root_on_u <- 0L
total_trees <- 0L
while (i <= length(tree_lines)) {
line <- trimws(tree_lines[i])
if (line == "") { i <- i + 1; next }
n_nodes <- suppressWarnings(as.integer(line))
if (is.na(n_nodes)) { i <- i + 1; next }
total_trees <- total_trees + 1L
root_line <- trimws(tree_lines[i + 1])
tokens <- strsplit(root_line, "\\s+")[[1]]
if (length(tokens) == 4) {
node_id <- as.integer(tokens[1])
var_idx  <- as.integer(tokens[2])
if (!is.na(node_id) && node_id == 1 && var_idx == 1L) {
root_on_u <- root_on_u + 1L
}
}
i <- i + n_nodes + 1
}
cat(sprintf("Trees splitting on u at root: %d / %d (%.1f%%)\n",
root_on_u, total_trees, 100 * root_on_u / total_trees))
