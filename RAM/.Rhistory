SIS <- function(Y, N = 1000, alpha = 0.91, sigma = 1, beta = 0.5) {
n <- length(Y)
X <- matrix(0, nrow = n, ncol = N)
logw <- matrix(0, nrow = n, ncol = N)
w <- matrix(0, nrow = n, ncol = N)
# initialize
X[1, ] <- rnorm(N, 0, sigma / sqrt(1 - alpha^2))
logw[1, ] <- dnorm(Y[1], mean = 0,
sd = beta * exp(X[1, ] / 2),
log = TRUE)
# normalize (log-sum-exp trick)
logw[1, ] <- logw[1, ] - max(logw[1, ])
w[1, ] <- exp(logw[1, ])
w[1, ] <- w[1, ] / sum(w[1, ])
for (t in 2:n) {
# propagate
X[t, ] <- alpha * X[t-1, ] + sigma * rnorm(N)
# update log-weights (same structure as yours)
logw[t, ] <- logw[t-1, ] +
dnorm(Y[t], mean = 0,
sd = beta * exp(X[t, ] / 2),
log = TRUE)
# normalize
logw[t, ] <- logw[t, ] - max(logw[t, ])
w[t, ] <- exp(logw[t, ])
w[t, ] <- w[t, ] / sum(w[t, ])
}
list(X = X, w = w)
}
filter_mean <- function(particles, weights) {
rowSums(particles * weights)
}
