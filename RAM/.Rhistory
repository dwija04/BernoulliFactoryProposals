mse_sis
ess_sis <- ess(sis_out$w)
SIS <- function(Y, N = 1000, alpha = 0.91, sigma = 1, beta = 0.5) {
n <- length(Y)
X <- matrix(0, nrow = n, ncol = N)
logw <- matrix(0, nrow = n, ncol = N)
w <- matrix(0, nrow = n, ncol = N)
# initialize
X[1, ] <- rnorm(N, 0, sigma / sqrt(1 - alpha^2))
logw[1, ] <- dnorm(Y[1], mean = 0,
sd = beta * exp(X[1, ] / 2),
log = TRUE)
logw[1, ] <- logw[1, ] - max(logw[1, ])
w[1, ] <- exp(logw[1, ])
w[1, ] <- w[1, ] / sum(w[1, ])
for (t in 2:n) {
X[t, ] <- alpha * X[t-1, ] + sigma * rnorm(N)
logw[t, ] <- logw[t-1, ] +
dnorm(Y[t], mean = 0,
sd = beta * exp(X[t, ] / 2),
log = TRUE)
logw[t, ] <- logw[t, ] - max(logw[t, ])
w[t, ] <- exp(logw[t, ])
w[t, ] <- w[t, ] / sum(w[t, ])
}
list(X = X, w = w)
}
Bootstrap <- function(Y, N = 1000, alpha = 0.91, sigma = 1, beta = 0.5) {
n <- length(Y)
X <- matrix(0, n, N)
w <- matrix(1/N, n, N)
X[1, ] <- rnorm(N, 0, sigma / sqrt(1 - alpha^2))
w[1, ] <- dnorm(Y[1], 0, beta * exp(X[1, ] / 2))
w[1, ] <- w[1, ] / sum(w[1, ])
for (t in 2:n) {
idx <- sample(1:N, N, replace = TRUE, prob = w[t-1, ])
X[t, ] <- alpha * X[t-1, idx] + sigma * rnorm(N)
w[t, ] <- dnorm(Y[t], 0, beta * exp(X[t, ] / 2))
w[t, ] <- w[t, ] / sum(w[t, ])
}
list(X = X, w = w)
}
filter_mean <- function(particles, weights) {
rowSums(particles * weights)
}
N_particles <- 1000
boot_out <- Bootstrap(Y, N = 1000)
xhat_boot <- rowSums(boot_out$X * boot_out$w)
mse_boot <- mean((xhat_boot - X)^2)
mse_boot
sis_out <- SIS(Y, N = 1000)
# filtering estimates
xhat_sis <- filter_mean(sis_out$X, sis_out$w)
mse_sis <- mean((xhat_sis - X)^2)
mse_sis
