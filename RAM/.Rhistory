Y <- numeric(n)
X[1] <- rnorm(1, mean = 0, sd = sigma/sqrt(1 - alpha^2))
Y[1] <- beta * exp(X[1]/2) * rnorm(1, mean = 0, sd = 1)
for(i in 2:n)
{
X[i] <- alpha * X[i-1] + rnorm(1, mean = 0, sd = sigma)
Y[i] <- beta * exp(X[i]/2) * rnorm(1, mean = 0, sd = 1)
}
plot(Y, type = "l", main = "Simulated Data", xlab = "Time", ylab = "Y")
SIS <- function(Y, N = 1000, alpha = 0.91, sigma = 1) {
n <- length(Y)
X <- matrix(0, nrow = n, ncol = N)
w <- matrix(0, nrow = n, ncol = N)
X[1, ] <- rnorm(N, 0, 1 / sqrt(1 - 0.91^2))
w[1, ] <- dnorm(Y[1], mean = 0, sd = 0.5 * exp(X[1, ] / 2)) #likelihood
w[1, ] <- w[1, ] / sum(w[1, ])
for (t in 2:n) {
X[t, ] <- alpha * X[t-1, ] + sigma*rnorm(N)
likelihoods <- dnorm(Y[t], mean = 0, sd = 0.5 * exp(X[t, ] / 2))
w[t, ] <- w[t-1, ] * likelihoods
# normalize
w[t, ] <- w[t, ] / sum(w[t, ])
}
list(X = X, w = w)
}
filter_mean <- function(particles, weights) {
rowSums(particles * weights)
}
N_particles <- 1000
sis_out <- SIS(Y, N = 1000)
# filtering estimates
xhat_sis <- filter_mean(sis_out$X, sis_out$w)
mse_sis <- mean((xhat_sis - X)^2)
mse_sis
plot(sis_out$weights[200, ], main = "SIS weights at t=200")
ess_sis <- ESS(sis_out$w)
