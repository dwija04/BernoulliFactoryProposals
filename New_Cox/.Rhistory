),
col = c(col_gray, col_teal, col_amber, col_purple),
lty = c(2, 1, 1, 3), lwd = c(1.8, 2.2, 2.2, 1.8),
bty = "n", cex = 0.85)
## -- Panel 4: Observed data scatter --
y_jit        <- Y
cens_idx     <- which(!obs)
y_jit[cens_idx] <- runif(length(cens_idx), -0.04, 0.04)
pt_cols <- ifelse(obs,
adjustcolor(col_blue, 0.55),
adjustcolor(col_red,  0.55))
plot(seq_len(n), y_jit, pch = 16, cex = 0.6, col = pt_cols,
xlab = "Index i", ylab = expression(Y[i]),
main = "Observed Y_i  (blue = observed, red = censored)",
cex.main = 1.0, cex.lab = 1.0,
panel.first = {
rect(par("usr")[1], par("usr")[3], par("usr")[2], par("usr")[4],
col = "#f9f9f9", border = NA)
grid(col = "white", lty = 1)
})
abline(h = 0, col = col_gray, lwd = 0.8, lty = 2)
legend("topright",
legend = c(sprintf("Observed (m = %d)", m),
sprintf("Censored (%d)", n - m)),
col = c(col_blue, col_red), pch = 16, bty = "n", cex = 0.9)
mtext(
sprintf("Gibbs sampler — censored Gaussian  |  n = %d, true theta = %.1f, prior N(%.0f, %.0f)",
n, theta_true, mu0, sigma2_0),
outer = TRUE, cex = 1.1, line = 1.2)
chain_raw
plot.ts(chain_raw)
library(ggplot2)
library(coda)
library(scales)
rtruncnorm_upper <- function(n, mu, upper) {
p_upper <- pnorm(upper, mean = mu, sd = 1)
u <- runif(n, min = 0, max = p_upper)
qnorm(u, mean = mu, sd = 1)
}
gibbs_censored_gaussian <- function(Y, obs_mask, mu0, sigma2_0,
n_iter = 6000, theta_init = 0.0,
seed = 42) {
set.seed(seed)
n      <- length(Y)
n_cens <- sum(!obs_mask)
theta_chain <- numeric(n_iter)
Z <- Y
theta <- theta_init
for (t in seq_len(n_iter)) {
if (n_cens > 0) {
Z[!obs_mask] <- rtruncnorm_upper(n_cens, mu = theta, upper = 0)
}
sigma2_n <- sigma2_0 / (n * sigma2_0 + 1)
mu_n     <- (sigma2_0 * sum(Z) + mu0) / (n * sigma2_0 + 1)
theta    <- rnorm(1, mean = mu_n, sd = sqrt(sigma2_n))
theta_chain[t] <- theta
}
theta_chain
}
## simulating data
set.seed(2024)
theta_true <- 1.5
n          <- 200
mu0        <- 0.0
sigma2_0   <- 4.0
X   <- rnorm(n, mean = theta_true, sd = 1)
Y   <- pmax(X, 0)
obs <- Y > 0
m   <- sum(obs)
# Run sampler
n_iter  <- 1e5
burn_in <- 0
chain_raw  <- gibbs_censored_gaussian(Y, obs, mu0, sigma2_0,
n_iter = n_iter, theta_init = 0.0)
chain_post <- chain_raw[(burn_in + 1):n_iter]
cat(sprintf("Posterior mean : %.4f\n", mean(chain_post)))
cat(sprintf("Posterior SD   : %.4f\n", sd(chain_post)))
cat(sprintf("95%% CI         : [%.4f, %.4f]\n",
quantile(chain_post, 0.025), quantile(chain_post, 0.975)))
mcmc_obj <- mcmc(chain_post)
eff_size <- effectiveSize(mcmc_obj)
cat(sprintf("Effective sample size: %.1f  (out of %d)\n",
eff_size, length(chain_post)))
par(mfrow = c(3, 2))
plot.ts(chain_raw)
