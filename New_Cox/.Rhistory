library(flexBART)
func_2 <- function(df){
if(ncol(df) < 2 ) stop("df must have at least 2 columns")
if(!all(abs(df[,1:5]-0.5) <= 1)){
stop("all entries in the first 2 columns of df must be between 0 and 1")
} else{
I1 <- ifelse(df[, 2] > 0.5, 1, 0)
return( 6*df[, 1] + (4 - 10*I1)*sin(pi*df[, 1]) - 4*I1 + 15)
}
}
