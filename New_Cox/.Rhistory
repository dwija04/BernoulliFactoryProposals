library(ggplot2)
library(coda)
library(scales)
rtruncnorm_upper <- function(n, mu, upper) {
p_upper <- pnorm(upper, mean = mu, sd = 1)
u <- runif(n, min = 0, max = p_upper)
qnorm(u, mean = mu, sd = 1)
}
gibbs_censored_gaussian <- function(Y, obs_mask, mu0, sigma2_0,
n_iter = 6000, theta_init = 0.0,
seed = 42) {
set.seed(seed)
n      <- length(Y)
n_cens <- sum(!obs_mask)
theta_chain <- numeric(n_iter)
Z <- Y
theta <- theta_init
for (t in seq_len(n_iter)) {
if (n_cens > 0) {
Z[!obs_mask] <- rtruncnorm_upper(n_cens, mu = theta, upper = 0)
}
sigma2_n <- sigma2_0 / (n * sigma2_0 + 1)
mu_n     <- (sigma2_0 * sum(Z) + mu0) / (n * sigma2_0 + 1)
theta    <- rnorm(1, mean = mu_n, sd = sqrt(sigma2_n))
theta_chain[t] <- theta
}
theta_chain
}
## simulating data
set.seed(2024)
theta_true <- 1.5
n          <- 200
mu0        <- 0.0
sigma2_0   <- 4.0
X   <- rnorm(n, mean = theta_true, sd = 1)
Y   <- pmax(X, 0)
obs <- Y > 0
m   <- sum(obs)
# Run sampler
n_iter  <- 1e5
burn_in <- 0
chain_raw  <- gibbs_censored_gaussian(Y, obs, mu0, sigma2_0,
n_iter = n_iter, theta_init = 0.0)
chain_post <- chain_raw[(burn_in + 1):n_iter]
cat(sprintf("Posterior mean : %.4f\n", mean(chain_post)))
cat(sprintf("Posterior SD   : %.4f\n", sd(chain_post)))
cat(sprintf("95%% CI         : [%.4f, %.4f]\n",
quantile(chain_post, 0.025), quantile(chain_post, 0.975)))
mcmc_obj <- mcmc(chain_post)
eff_size <- effectiveSize(mcmc_obj)
cat(sprintf("Effective sample size: %.1f  (out of %d)\n",
eff_size, length(chain_post)))
par(mfrow = c(1, 3))
plot.ts(chain_raw)
acf(chain_raw, lag.max = 50, main = "ACF (full chain)")
plot(density(chain_post))
abline(v = theta_true, col = "red", lwd = 2, lty = 2)
abline(v = mean(chain_post), col = "blue", lwd = 2, lty = 3)
legend("topright",
legend = c(sprintf("True theta = %.2f", theta_true),
sprintf("Post. mean = %.2f", mean(chain_post))),
col = c("red", "blue"), lty = c(2, 3), lwd = 2, bty = "n")
m
n
par(mfrow = c(1, 3), oma = c(0, 0, 3, 0),
mar = c(4.5, 4.5, 3, 1.5), bg = "white")
scenarios <- list(
list(theta =  1.28, label = "~10% censored"),
list(theta =  0.00, label = "~50% censored"),
list(theta = -1.28, label = "~90% censored")
)
for (sc in scenarios) {
set.seed(7)
th  <- sc$theta
X2  <- rnorm(300, mean = th, sd = 1)
Y2  <- pmax(X2, 0)
ob2 <- Y2 > 0
fc  <- mean(!ob2)
s2 <- gibbs_censored_gaussian(Y2, ob2, mu0 = 0, sigma2_0 = 4,
n_iter = 6000, theta_init = 0)
s2 <- s2[1001:6000]
tg <- seq(th - 1.8, th + 1.8, length.out = 400)
hist(s2, breaks = 55, probability = TRUE,
col    = adjustcolor(col_blue, 0.4),
border = adjustcolor(col_blue, 0.6),
xlab   = expression(theta), ylab = "Density",
main   = sprintf("%s", sc$label, fc),
cex.main = 1.0, cex.lab = 1.0,
panel.first = {
rect(par("usr")[1], par("usr")[3], par("usr")[2], par("usr")[4],
col = "#f9f9f9", border = NA)
})
lines(tg, dnorm(tg, mean(s2), sd(s2)), col = col_teal, lwd = 2.2)
abline(v = th,       col = col_amber,  lwd = 2.0, lty = 2)
abline(v = mean(s2), col = col_purple, lwd = 1.8, lty = 3)
legend("topright",
legend = c(sprintf("True theta = %.2f", th),
sprintf("Post. mean = %.2f", mean(s2))),
col = c(col_amber, col_purple),
lty = c(2, 3), lwd = 1.8, bty = "n", cex = 0.85)
}
