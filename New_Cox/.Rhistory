parse_tree <- function(tree_string) {
lines <- strsplit(trimws(tree_string), "\n")[[1]]
lines <- lines[nchar(trimws(lines)) > 0]
do.call(rbind, lapply(lines, function(line) {
parts <- strsplit(trimws(line), " ")[[1]]
data.frame(
node_id = as.integer(parts[1]),
type    = parts[2],
stringsAsFactors = FALSE
)
}))
}
# Get max depth from a tree string
tree_depth <- function(tree_string) {
df <- parse_tree(tree_string)
internal_nodes <- df$node_id[df$type == "r"]
n_internal <- length(internal_nodes)
# For a full binary tree: depth = log2(n_leaves) = log2(n_internal + 1)
floor(log2(n_internal + 1))
}
# Apply to one tree
tree_depth(fit$trees[[1]][[1]])
