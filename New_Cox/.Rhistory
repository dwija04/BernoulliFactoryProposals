solve_optimal <- function(n, alpha = 0.05)
{
df <- 2 * n
objective <- function(a) {
b <- qchisq(pchisq(a, df) + (1 - alpha), df)
1/a - 1/b
}
a_max <- qchisq(alpha, df)
a_grid <- seq(1e-6, a_max, length.out = 5000)
obj_vals <- sapply(a_grid, objective)
a_star <- a_grid[which.min(obj_vals)]
b_star <- qchisq(pchisq(a_star, df) + (1 - alpha), df)
list(a = a_star, b = b_star)
}
results <- map_dfr(c(5, 10, 20, 50, 100), function(n) {
alpha <- 0.05
z     <- qnorm(1 - alpha/2)
df    <- 2 * n
# MLE-based equal-tails interval expected length (part b)
len_mle <- 2 * z / sqrt(n) / (1 - z^2 / n)
# Optimal interval
opt    <- solve_optimal(n, alpha)
a_star <- opt$a
b_star <- opt$b
len_opt <- 2 * n * (1/a_star - 1/b_star)  # as multiple of mu
data.frame(
n       = n,
a_star  = round(a_star, 4),
b_star  = round(b_star, 4),
len_mle = round(len_mle, 4),   # as multiple of mu
len_opt = round(len_opt, 4),   # as multiple of mu
gain_pct = round((len_mle - len_opt) / len_mle * 100, 2)
)
})
print(results)
