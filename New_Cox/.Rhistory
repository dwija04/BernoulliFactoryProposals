library(mcmcse)
source("cox_functions.R")
load("estimated-cov.RData")
# load("cox-data.RData")
load("cox-data.RData")
ns <- xn[[1]]
x <- xn[[2]]
c <- xn[[3]]
t <- xn[[4]]
cov <- xn[[5]]
m <- xn[[6]]
delta_m <- xn[[7]]
N0 <- xn[[8]]
mu <- xn[[9]]
N <- 1e4
#The posterior
cov.svd <- svd(cov)
sqrt.cov <- cov.svd$u %*% diag(cov.svd$d^(1/2), m) %*% t(cov.svd$v)
max(cov - sqrt.cov %*% sqrt.cov)
inv.cov <- qr.solve(cov)
eta <- 0.1
cov.init <- eta * diag(m)
sqrt.cov.init <- sqrt(eta) * diag(m)
foo <- cox_rwmh(1e5, init = rep(1, m), ns = ns, x, c, t, cov, sqrt.cov.init, eta)
foo <- cox_rwmh(1e3, init = rep(1, m), ns = ns, x, c, t, cov, sqrt.cov.init, eta)
foo[[2]]
eta <- 0.01
cov.init <- eta * diag(m)
eta <- 0.01
cov.init <- eta * diag(m)
sqrt.cov.init <- sqrt(eta) * diag(m)
foo <- cox_rwmh(1e3, init = rep(1, m), ns = ns, x, c, t, cov, sqrt.cov.init, eta)
foo[[2]]
eta <- 0.06
cov.init <- eta * diag(m)
sqrt.cov.init <- sqrt(eta) * diag(m)
foo <- cox_rwmh(1e3, init = rep(1, m), ns = ns, x, c, t, cov, sqrt.cov.init, eta)
foo[[2]]
plot(density(foo[[1]][, 100]), main = "Initial MCMC run with identity covariance", xlab = "beta_100")
prop.cov <- cov(foo[[1]])
prop.cov.svd <- svd(prop.cov)
prop.sqrt.cov <- prop.cov.svd$u %*% diag(prop.cov.svd$d^(1/2), m) %*% t(prop.cov.svd$v)
max(prop.cov - prop.sqrt.cov %*% prop.sqrt.cov)
prop.inv.cov <- qr.solve(prop.cov)
bf_time <- system.time(bf_chain <- cox_bf(N, init = rep(1,  m), ns = ns, x, c, t, cov, prop.cov, prop.sqrt.cov, eta = 0.1))
